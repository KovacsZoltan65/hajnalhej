INERTIA_SSR_THROW_ON_ERROR=false
INERTIA_ENSURE_PAGES_EXIST=false
INERTIA_ENCRYPT_HISTORY=false

HH_LOAD_TEST_PREFIX="LT"
HH_LOAD_TEST_DAYS=30
HH_LOAD_TEST_START_DATE=
HH_LOAD_TEST_RESET=true
HH_LOAD_TEST_SEED=20260427
HH_LOAD_TEST_WASTE_ENABLED=true
HH_LOAD_TEST_WASTE_SEED=
HH_LOAD_TEST_PRODUCT_WASTE_DAILY_CHANCE=65
HH_LOAD_TEST_PRODUCT_WASTE_ITEM_CHANCE=18
HH_LOAD_TEST_PRODUCT_WASTE_RATE_MIN=0.03
HH_LOAD_TEST_PRODUCT_WASTE_RATE_MAX=0.12
HH_LOAD_TEST_INGREDIENT_WASTE_DAILY_CHANCE=45
HH_LOAD_TEST_INGREDIENT_WASTE_ITEM_CHANCE=12
HH_LOAD_TEST_INGREDIENT_WASTE_RATE_MIN=0.002
HH_LOAD_TEST_INGREDIENT_WASTE_RATE_MAX=0.015
HH_NOISE_PAYMENT_PENDING_RATE=0.10
HH_NOISE_PAYMENT_FAILED_RATE=0.03
