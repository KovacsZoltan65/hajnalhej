APP_NAME="Hajnalhej Testing"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=4

LOG_CHANNEL=array
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Default test runner database.
# phpunit.xml also enforces this database for deterministic local test runs.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hajnalhej_test
DB_USERNAME=root
DB_PASSWORD=
DB_FOREIGN_KEYS=true
DB_URL=

SESSION_DRIVER=array
BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=array
CACHE_TAG_DEBUG=false

MAIL_MAILER=array
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

INERTIA_SSR_ENABLED=false
INERTIA_ENSURE_PAGES_EXIST=false
INERTIA_ENCRYPT_HISTORY=false

VITE_APP_NAME="${APP_NAME}"
